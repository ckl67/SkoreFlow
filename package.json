{
  "name": "skoreflow",
  "private": true,
  "workspaces": [
    "frontend",
    "testauto/backend"
  ],
  "scripts": {
    "-- MICROSERVICES --": "",
    "  🐍 thumbnail": "cd microservice/thumbnail && make",
    "-- BACKEND DEV --": "",
    "  🐹🌀backend:air": "cd backend && make air-dev",
    "  🐹backend:run": "cd backend && make run",
    "-- BACKEND TEST (SEED DATA) --": "",
    "  🐹🌀🧪backend:air (RegToken)": "cd backend && make air-test",
    "  🐹🧪backend:run (RegToken)": "cd backend && make run-test",
    "-- FRONTEND DEV VM --": "",
    "  ⚛️🖥️frontend:dev-vm": "npm run run:mode-vm-dev -w frontend",
    "-- FRONTEND DEV LOCAL": "",
    "  ⚛️frontend:dev": "npm run run:mode-dev -w frontend",
    "-- BACKEND AUTO TEST --": "",
    " 🐹🚦smoke": "cd testauto/backend && bash auto-test.sh",
    "-- UTILITIES --": "",
    "  🧹clean:db-storage": "cd backend && make clean",
    "  ☠️kill:services": "sudo fuser -k 8080/tcp || true && sudo fuser -k 5001/tcp || true && sudo fuser -k 5173/tcp || true",
    "// TESTING AND OVERALL QUALITY --- //": "",
    "test:e2e-with-ui": "playwright test --ui",
    "test:e2e": "playwright test",
    "// ⚙️ OTHER //": "",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  }
}
