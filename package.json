{
  "name": "skoreflow",
  "private": true,
  "workspaces": [
    "frontend",
    "testauto/backend"
  ],
  "scripts": {
    "thumbnail:": "cd microservice/thumbnail && make",
    "----": "",
    "backend:air(dev)": "cd backend && make air-dev",
    "backend:air(test)": "cd backend && make air-test",
    "backend:run(test)": "cd backend && make run-test",
    "-----": "",
    "frontend:vite(test)": "cd frontend && vite --mode test",
    "frontend:vite(dev)": "cd frontend && vite",
    "frontend:run(build)": "cd frontend && vite preview",
    "frontend:build": "cd frontend && vite build",
    "------": "",
    "test:e2e-with-ui": "playwright test --ui",
    "test:e2e ": "playwright test",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  }
}
