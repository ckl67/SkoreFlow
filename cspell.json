{
  "version": "0.2",
  "language": "en",
  "ignorePaths": [
    "node_modules/**",
    ".cspell/custom-dictionary.txt",
    "vendor/**",
    ".git/**",
    ".vscode/**",
    ".gitignore", // specific file
    "**/.*" // ignore ghost files
  ],
  "dictionaries": ["custom-dictionary"],
  "dictionaryDefinitions": [
    {
      "name": "custom-dictionary",
      "path": ".cspell/custom-dictionary.txt",
      "addWords": true
    }
  ]
}
