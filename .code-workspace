{
  "folders": [
    {
      "name": "📦 SkoreFlow (Root)",
      "path": ".",
    },
    {
      "name": "🐹 Backend (Go)",
      "path": "backend",
    },
    {
      "name": "⚛️ Frontend (TS/React)",
      "path": "frontend",
    },
    {
      "name": "📁 Shared (Test Backend - Frontend)",
      "path": "shared",
    },
    {
      "name": "🐍 Microservices",
      "path": "microservice",
    },
    {
      "name": "🎭 Test Auto (Playwright/Python)",
      "path": "testauto",
    },
    {
      "name": "📚 Documentation",
      "path": "docs",
    },
  ],
  "settings": {
    "git.ignoredRepositories": ["backend", "frontend", "microservice", "testauto"],

    "files.exclude": {
      // Hides these folders ONLY in the root folder to avoid visual duplicates
      // --- STRICT masking at the root only (with ./) ---
      "./backend": true,
      "./frontend": true,
      "./shared": true,
      "./microservice": true,
      "./testauto": true,
      "./docs": true,

      // --- Hiding technical and temporary folders (New) ---
      "**/node_modules": true,
      "tmp": true,
      "playwright-report": true,
      "test-results": true,
    },
  },
}
