// ${workspaceFolder} = Workspace Folder
// ${fileDirname} = Current file

{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Chrome",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173"
    },
    {
      "name": "Debug Vitest File",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/node_modules/vitest/vitest.mjs",
      "args": ["run", "${file}"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal"
    },

    {
      "name": "Debug Server",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/backend/cmd/server",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Debug CLI (no args)",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}backend/cmd/cli",
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "Debug CLI (list users)",
      "type": "go",
      "request": "launch",
      "mode": "debug",
      "program": "${workspaceFolder}/backend/cmd/cli",
      "cwd": "${workspaceFolder}",
      "args": ["-list-users"]
    }
  ]
}
